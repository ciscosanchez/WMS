# Database
DATABASE_URL="postgresql://ramola:ramola_dev@localhost:5432/ramola_wms?schema=public"

# Auth
AUTH_SECRET="generate-a-secure-secret-here"
CF_DNS_API_TOKEN=""
AUTH_URL="http://localhost:3000"

# MinIO / S3
S3_ENDPOINT="localhost"
S3_PORT=9000
S3_ACCESS_KEY="ramola"
S3_SECRET_KEY="ramola_dev"
S3_BUCKET="ramola-wms"
S3_USE_SSL=false

# Tenant resolution: "header" (dev) or "subdomain" (prod)
TENANT_RESOLUTION="header"

# DocAI — document intelligence service
DOCAI_URL="http://localhost:3001"
DOCAI_API_KEY=""
DOCAI_TIMEOUT_MS="120000"

# Mock data mode — set to "false" when database is connected
USE_MOCK_DATA="true"
NEXT_PUBLIC_USE_MOCK_DATA="true"

# DispatchPro TMS integration
# WMS_API_KEY: shared secret DispatchPro sends in X-API-Key to authenticate calls to WMS
# DISPATCH_PRO_URL: internal Docker URL for DispatchPro (or external if separate deployment)
# DISPATCH_PRO_API_KEY: key WMS sends when calling DispatchPro (same value as WMS_API_KEY for single-tenant)
WMS_API_KEY=""
DISPATCH_PRO_URL="http://localhost:3001"
DISPATCH_PRO_API_KEY=""
