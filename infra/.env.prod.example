# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=ramola
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=ramola
WMS_DATABASE_URL=postgresql://ramola:CHANGE_ME@postgres:5432/ramola_wms?schema=public
DISPATCH_DATABASE_URL=postgresql://ramola:CHANGE_ME@postgres:5432/ramola_dispatch

# ── WMS ──────────────────────────────────────────────────────
AUTH_SECRET=CHANGE_ME_64_char_random_string
# Generate with: openssl rand -hex 32

# ── DocAI ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
CLAUDE_MODEL=claude-sonnet-4-6
DOCAI_API_KEY=CHANGE_ME_shared_secret_between_wms_and_docai
LOG_LEVEL=info

# ── DispatchPro ──────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_32_char_random
REFRESH_TOKEN_SECRET=CHANGE_ME_32_char_random
ENCRYPTION_KEY=CHANGE_ME_32_char_random
WMS_API_KEY=CHANGE_ME_shared_secret_between_wms_and_dispatch

# ── S3 / MinIO (optional — for file uploads) ────────────────
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=

# ── Shopify Integration ──────────────────────────────────────
SHOPIFY_SHOP_DOMAIN=yourstore.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpua_CHANGE_ME
SHOPIFY_API_VERSION=2026-01
# SHOPIFY_LOCATION_ID=  # Auto-detected if not set
SHOPIFY_WEBHOOK_SECRET=CHANGE_ME  # From Shopify webhook settings

# Tenant slug for webhook receiver (must match the tenant's slug in DB)
ARMSTRONG_TENANT_SLUG=armstrong
