generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/public-client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tenants ────────────────────────────────────────────

enum TenantStatus {
  active
  suspended
  provisioning
}

enum TenantPlan {
  starter
  professional
  enterprise
}

model Tenant {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  dbSchema  String       @unique @map("db_schema")
  status    TenantStatus @default(provisioning)
  plan      TenantPlan   @default(starter)
  settings  Json         @default("{}")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  tenantUsers TenantUser[]

  @@map("tenants")
}

// ─── Users ──────────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String    @map("password_hash")
  name               String
  isSuperadmin       Boolean   @default(false) @map("is_superadmin")
  authVersion        Int       @default(0) @map("auth_version")
  locale             String?   // null = use tenant default
  passwordSetToken   String?   @unique @map("password_set_token")
  passwordSetExpires DateTime? @map("password_set_expires")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  tenantUsers TenantUser[]
  sessions    Session[]
  accounts    Account[]

  @@map("users")
}

enum TenantRole {
  admin
  manager
  warehouse_worker
  viewer
}

model TenantUser {
  id             String     @id @default(cuid())
  tenantId       String     @map("tenant_id")
  userId         String     @map("user_id")
  role           TenantRole @default(viewer)
  portalClientId String?    @map("portal_client_id") // If set, user is a portal user scoped to this client
  permissionOverrides Json  @default("{\"grants\":[],\"denies\":[]}") @map("permission_overrides")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("tenant_users")
}

// ─── NextAuth Tables ────────────────────────────────────

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
