generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/tenant-client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Clients (Cargo Owners) ────────────────────────────

model Client {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  contactName   String?  @map("contact_name")
  contactEmail  String?  @map("contact_email")
  contactPhone  String?  @map("contact_phone")
  address       String?
  city          String?
  state         String?
  country       String?
  zipCode       String?  @map("zip_code")
  taxId         String?  @map("tax_id")
  notes         String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products          Product[]
  inboundShipments  InboundShipment[]
  orders            Order[]

  @@map("clients")
}

// ─── Products ───────────────────────────────────────────

model Product {
  id          String  @id @default(cuid())
  clientId    String  @map("client_id")
  sku         String
  name        String
  description String?
  hsCode      String? @map("hs_code")
  barcode     String?
  weight      Decimal? @db.Decimal(10, 4)
  weightUnit  String?  @default("lb") @map("weight_unit")
  length      Decimal? @db.Decimal(10, 2)
  width       Decimal? @db.Decimal(10, 2)
  height      Decimal? @db.Decimal(10, 2)
  dimUnit     String?  @default("in") @map("dim_unit")
  baseUom     String   @default("EA") @map("base_uom")
  trackLot    Boolean  @default(false) @map("track_lot")
  trackSerial Boolean  @default(false) @map("track_serial")
  minStock    Int?     @map("min_stock")
  maxStock    Int?     @map("max_stock")
  imageUrl    String?  @map("image_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  client            Client             @relation(fields: [clientId], references: [id])
  uomConversions    UomConversion[]
  inboundLines      InboundShipmentLine[]
  inventory         Inventory[]
  inventoryTransactions InventoryTransaction[]
  putawayRules      PutawayRule[]
  orderLines        OrderLine[]
  pickTaskLines     PickTaskLine[]
  shipmentItems     ShipmentItem[]

  @@unique([clientId, sku])
  @@map("products")
}

model UomConversion {
  id        String  @id @default(cuid())
  productId String  @map("product_id")
  fromUom   String  @map("from_uom")
  toUom     String  @map("to_uom")
  factor    Decimal @db.Decimal(10, 4)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, fromUom, toUom])
  @@map("uom_conversions")
}

// ─── Warehouse Layout ───────────────────────────────────

model Warehouse {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  zones Zone[]

  @@map("warehouses")
}

model Zone {
  id          String @id @default(cuid())
  warehouseId String @map("warehouse_id")
  code        String
  name        String
  type        String @default("storage") // storage, staging, dock, quarantine

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  aisles    Aisle[]

  @@unique([warehouseId, code])
  @@map("zones")
}

model Aisle {
  id     String @id @default(cuid())
  zoneId String @map("zone_id")
  code   String

  zone  Zone   @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  racks Rack[]

  @@unique([zoneId, code])
  @@map("aisles")
}

model Rack {
  id      String @id @default(cuid())
  aisleId String @map("aisle_id")
  code    String

  aisle   Aisle   @relation(fields: [aisleId], references: [id], onDelete: Cascade)
  shelves Shelf[]

  @@unique([aisleId, code])
  @@map("racks")
}

model Shelf {
  id     String @id @default(cuid())
  rackId String @map("rack_id")
  code   String

  rack Rack @relation(fields: [rackId], references: [id], onDelete: Cascade)
  bins Bin[]

  @@unique([rackId, code])
  @@map("shelves")
}

enum BinType {
  standard
  bulk
  pick
}

enum BinStatus {
  available
  full
  reserved
  blocked
}

model Bin {
  id        String    @id @default(cuid())
  shelfId   String    @map("shelf_id")
  code      String
  barcode   String    @unique
  type      BinType   @default(standard)
  status    BinStatus @default(available)
  capacity  Int?
  createdAt DateTime  @default(now()) @map("created_at")

  shelf               Shelf                @relation(fields: [shelfId], references: [id], onDelete: Cascade)
  inventory           Inventory[]
  receivingTransactions ReceivingTransaction[]
  inventoryTransactionsFrom InventoryTransaction[] @relation("from_bin")
  inventoryTransactionsTo   InventoryTransaction[] @relation("to_bin")
  putawayRules        PutawayRule[]
  pickTaskLines       PickTaskLine[]

  @@unique([shelfId, code])
  @@map("bins")
}

// ─── Receiving Module ───────────────────────────────────

enum ShipmentStatus {
  draft
  expected
  arrived
  receiving
  inspection
  completed
  cancelled
}

model InboundShipment {
  id              String         @id @default(cuid())
  shipmentNumber  String         @unique @map("shipment_number")
  clientId        String         @map("client_id")
  carrier         String?
  trackingNumber  String?        @map("tracking_number")
  bolNumber       String?        @map("bol_number")
  poNumber        String?        @map("po_number")
  status          ShipmentStatus @default(draft)
  expectedDate    DateTime?      @map("expected_date")
  arrivedDate     DateTime?      @map("arrived_date")
  completedDate   DateTime?      @map("completed_date")
  notes           String?
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  client       Client                @relation(fields: [clientId], references: [id])
  lines        InboundShipmentLine[]
  transactions ReceivingTransaction[]
  discrepancies ReceivingDiscrepancy[]
  documents    Document[]

  @@map("inbound_shipments")
}

model InboundShipmentLine {
  id           String  @id @default(cuid())
  shipmentId   String  @map("shipment_id")
  productId    String  @map("product_id")
  expectedQty  Int     @map("expected_qty")
  receivedQty  Int     @default(0) @map("received_qty")
  uom          String  @default("EA")
  lotNumber    String? @map("lot_number")
  serialNumber String? @map("serial_number")
  notes        String?

  shipment     InboundShipment      @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  product      Product              @relation(fields: [productId], references: [id])
  transactions ReceivingTransaction[]

  @@map("inbound_shipment_lines")
}

enum ItemCondition {
  good
  damaged
  quarantine
}

enum InspectionStatus {
  pending
  passed
  failed
  waived
}

model ReceivingTransaction {
  id               String           @id @default(cuid())
  shipmentId       String           @map("shipment_id")
  lineId           String           @map("line_id")
  binId            String?          @map("bin_id")
  quantity         Int
  condition        ItemCondition    @default(good)
  inspectionStatus InspectionStatus @default(pending) @map("inspection_status")
  lotNumber        String?          @map("lot_number")
  serialNumber     String?          @map("serial_number")
  receivedBy       String           @map("received_by")
  receivedAt       DateTime         @default(now()) @map("received_at")
  notes            String?

  shipment InboundShipment     @relation(fields: [shipmentId], references: [id])
  line     InboundShipmentLine @relation(fields: [lineId], references: [id])
  bin      Bin?                @relation(fields: [binId], references: [id])

  @@map("receiving_transactions")
}

model InspectionChecklist {
  id          String @id @default(cuid())
  name        String
  description String?
  isActive    Boolean @default(true) @map("is_active")

  items   InspectionChecklistItem[]
  results InspectionResult[]

  @@map("inspection_checklists")
}

model InspectionChecklistItem {
  id          String @id @default(cuid())
  checklistId String @map("checklist_id")
  label       String
  type        String @default("pass_fail") // pass_fail, numeric, text
  sortOrder   Int    @default(0) @map("sort_order")

  checklist InspectionChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  results   InspectionResult[]

  @@map("inspection_checklist_items")
}

model InspectionResult {
  id          String  @id @default(cuid())
  checklistId String  @map("checklist_id")
  itemId      String  @map("item_id")
  entityType  String  @map("entity_type") // shipment, transaction
  entityId    String  @map("entity_id")
  result      String
  notes       String?
  inspectedBy String  @map("inspected_by")
  inspectedAt DateTime @default(now()) @map("inspected_at")

  checklist InspectionChecklist     @relation(fields: [checklistId], references: [id])
  item      InspectionChecklistItem @relation(fields: [itemId], references: [id])

  @@map("inspection_results")
}

enum DiscrepancyType {
  shortage
  overage
  damage
}

enum DiscrepancyStatus {
  open
  investigating
  resolved
  closed
}

model ReceivingDiscrepancy {
  id           String            @id @default(cuid())
  shipmentId   String            @map("shipment_id")
  type         DiscrepancyType
  status       DiscrepancyStatus @default(open)
  description  String
  productId    String?           @map("product_id")
  expectedQty  Int?              @map("expected_qty")
  actualQty    Int?              @map("actual_qty")
  resolution   String?
  resolvedBy   String?           @map("resolved_by")
  resolvedAt   DateTime?         @map("resolved_at")
  createdAt    DateTime          @default(now()) @map("created_at")

  shipment InboundShipment @relation(fields: [shipmentId], references: [id])

  @@map("receiving_discrepancies")
}

model Document {
  id         String   @id @default(cuid())
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  type       String   // bol, packing_list, photo, inspection_report
  fileName   String   @map("file_name")
  fileUrl    String   @map("file_url")
  fileSize   Int?     @map("file_size")
  mimeType   String?  @map("mime_type")
  uploadedBy String   @map("uploaded_by")
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  shipment InboundShipment? @relation(fields: [entityId], references: [id])

  @@map("documents")
}

// ─── Inventory Module ───────────────────────────────────

model Inventory {
  id           String   @id @default(cuid())
  productId    String   @map("product_id")
  binId        String   @map("bin_id")
  lotNumber    String?  @map("lot_number")
  serialNumber String?  @map("serial_number")
  onHand       Int      @default(0) @map("on_hand")
  allocated    Int      @default(0)
  available    Int      @default(0) // computed: on_hand - allocated
  uom          String   @default("EA")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id])
  bin     Bin     @relation(fields: [binId], references: [id])

  @@unique([productId, binId, lotNumber, serialNumber])
  @@map("inventory")
}

enum TransactionType {
  receive
  putaway
  move
  adjust
  count
  allocate
  deallocate
}

model InventoryTransaction {
  id              String          @id @default(cuid())
  type            TransactionType
  productId       String          @map("product_id")
  fromBinId       String?         @map("from_bin_id")
  toBinId         String?         @map("to_bin_id")
  quantity         Int
  lotNumber       String?         @map("lot_number")
  serialNumber    String?         @map("serial_number")
  referenceType   String?         @map("reference_type") // shipment, adjustment, cycle_count
  referenceId     String?         @map("reference_id")
  reason          String?
  performedBy     String          @map("performed_by")
  performedAt     DateTime        @default(now()) @map("performed_at")

  product Product @relation(fields: [productId], references: [id])
  fromBin Bin?    @relation("from_bin", fields: [fromBinId], references: [id])
  toBin   Bin?    @relation("to_bin", fields: [toBinId], references: [id])

  @@map("inventory_transactions")
}

enum PutawayStrategy {
  fixed
  zone
  closest_empty
  consolidate
}

model PutawayRule {
  id         String          @id @default(cuid())
  productId  String?         @map("product_id")
  binId      String?         @map("bin_id")
  zoneCode   String?         @map("zone_code")
  strategy   PutawayStrategy @default(closest_empty)
  priority   Int             @default(0)
  isActive   Boolean         @default(true) @map("is_active")

  product Product? @relation(fields: [productId], references: [id])
  bin     Bin?     @relation(fields: [binId], references: [id])

  @@map("putaway_rules")
}

enum AdjustmentStatus {
  draft
  pending_approval
  approved
  rejected
  completed
}

model InventoryAdjustment {
  id          String           @id @default(cuid())
  adjustmentNumber String      @unique @map("adjustment_number")
  type        String           @default("adjustment") // adjustment, cycle_count
  status      AdjustmentStatus @default(draft)
  reason      String?
  notes       String?
  createdBy   String           @map("created_by")
  approvedBy  String?          @map("approved_by")
  approvedAt  DateTime?        @map("approved_at")
  completedAt DateTime?        @map("completed_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  lines AdjustmentLine[]

  @@map("inventory_adjustments")
}

model AdjustmentLine {
  id           String @id @default(cuid())
  adjustmentId String @map("adjustment_id")
  productId    String @map("product_id")
  binId        String @map("bin_id")
  lotNumber    String? @map("lot_number")
  serialNumber String? @map("serial_number")
  systemQty    Int    @map("system_qty")
  countedQty   Int    @map("counted_qty")
  variance     Int    // computed: counted_qty - system_qty
  notes        String?

  adjustment InventoryAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)

  @@map("adjustment_lines")
}

enum CycleCountFrequency {
  daily
  weekly
  monthly
  quarterly
}

enum CycleCountMethod {
  abc
  zone
  full
  random
}

model CycleCountPlan {
  id        String              @id @default(cuid())
  name      String
  method    CycleCountMethod
  frequency CycleCountFrequency
  isActive  Boolean             @default(true) @map("is_active")
  config    Json                @default("{}") // zone codes, ABC categories, etc.
  lastRunAt DateTime?           @map("last_run_at")
  nextRunAt DateTime?           @map("next_run_at")
  createdAt DateTime            @default(now()) @map("created_at")

  @@map("cycle_count_plans")
}

// ─── Fulfillment / E-Commerce Module ────────────────────

model SalesChannel {
  id        String  @id @default(cuid())
  name      String
  type      String  // shopify, amazon, walmart, manual, api
  config    Json    @default("{}")  // API keys, store URL, etc.
  isActive  Boolean @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders Order[]

  @@map("sales_channels")
}

enum OrderStatus {
  pending
  awaiting_fulfillment
  allocated
  picking
  picked
  packing
  packed
  shipped
  delivered
  cancelled
  on_hold
  backordered
}

enum OrderPriority {
  standard
  expedited
  rush
  same_day
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique @map("order_number")
  externalId      String?       @map("external_id")  // marketplace order ID
  channelId       String?       @map("channel_id")
  clientId        String        @map("client_id")
  status          OrderStatus   @default(pending)
  priority        OrderPriority @default(standard)
  // Ship-to address
  shipToName      String        @map("ship_to_name")
  shipToAddress1  String        @map("ship_to_address1")
  shipToAddress2  String?       @map("ship_to_address2")
  shipToCity      String        @map("ship_to_city")
  shipToState     String?       @map("ship_to_state")
  shipToZip       String        @map("ship_to_zip")
  shipToCountry   String        @default("US") @map("ship_to_country")
  shipToPhone     String?       @map("ship_to_phone")
  shipToEmail     String?       @map("ship_to_email")
  // Shipping
  requestedCarrier String?      @map("requested_carrier")
  requestedService String?      @map("requested_service")
  shippingMethod   String?      @map("shipping_method")
  // Dates
  orderDate       DateTime      @default(now()) @map("order_date")
  shipByDate      DateTime?     @map("ship_by_date")
  shippedDate     DateTime?     @map("shipped_date")
  deliveredDate   DateTime?     @map("delivered_date")
  cancelledDate   DateTime?     @map("cancelled_date")
  // Totals
  totalItems      Int           @default(0) @map("total_items")
  totalWeight     Decimal?      @db.Decimal(10, 4) @map("total_weight")
  notes           String?
  tags            String?       // comma-separated tags for filtering
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  channel   SalesChannel? @relation(fields: [channelId], references: [id])
  client    Client        @relation(fields: [clientId], references: [id])
  lines     OrderLine[]
  shipments Shipment[]
  picks     PickTask[]

  @@index([status])
  @@index([clientId])
  @@index([orderDate])
  @@map("orders")
}

model OrderLine {
  id          String  @id @default(cuid())
  orderId     String  @map("order_id")
  productId   String  @map("product_id")
  quantity    Int
  pickedQty   Int     @default(0) @map("picked_qty")
  packedQty   Int     @default(0) @map("packed_qty")
  uom         String  @default("EA")
  unitPrice   Decimal? @db.Decimal(10, 2) @map("unit_price")
  lotNumber   String?  @map("lot_number")
  serialNumber String? @map("serial_number")
  notes       String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_lines")
}

// ─── Picking ────────────────────────────────────────────

enum PickMethod {
  single_order
  batch
  wave
  zone
}

enum PickTaskStatus {
  pending
  assigned
  in_progress
  completed
  short_picked
}

model PickTask {
  id          String         @id @default(cuid())
  taskNumber  String         @unique @map("task_number")
  orderId     String?        @map("order_id")
  method      PickMethod     @default(single_order)
  status      PickTaskStatus @default(pending)
  assignedTo  String?        @map("assigned_to")
  startedAt   DateTime?      @map("started_at")
  completedAt DateTime?      @map("completed_at")
  createdAt   DateTime       @default(now()) @map("created_at")

  order Order? @relation(fields: [orderId], references: [id])
  lines PickTaskLine[]

  @@map("pick_tasks")
}

model PickTaskLine {
  id          String  @id @default(cuid())
  taskId      String  @map("task_id")
  productId   String  @map("product_id")
  binId       String  @map("bin_id")
  quantity    Int
  pickedQty   Int     @default(0) @map("picked_qty")
  lotNumber   String? @map("lot_number")
  serialNumber String? @map("serial_number")

  task    PickTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  product Product  @relation(fields: [productId], references: [id])
  bin     Bin      @relation(fields: [binId], references: [id])

  @@map("pick_task_lines")
}

// ─── Packing & Shipping ────────────────────────────────

model Shipment {
  id              String   @id @default(cuid())
  shipmentNumber  String   @unique @map("shipment_number")
  orderId         String   @map("order_id")
  carrier         String?
  service         String?
  trackingNumber  String?  @map("tracking_number")
  labelUrl        String?  @map("label_url")
  // Package dimensions
  packageWeight   Decimal? @db.Decimal(10, 4) @map("package_weight")
  packageLength   Decimal? @db.Decimal(10, 2) @map("package_length")
  packageWidth    Decimal? @db.Decimal(10, 2) @map("package_width")
  packageHeight   Decimal? @db.Decimal(10, 2) @map("package_height")
  shippingCost    Decimal? @db.Decimal(10, 2) @map("shipping_cost")
  // Status
  status          String   @default("pending") // pending, label_created, shipped, delivered
  shippedAt       DateTime? @map("shipped_at")
  deliveredAt     DateTime? @map("delivered_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])
  items ShipmentItem[]

  @@map("shipments")
}

model ShipmentItem {
  id          String @id @default(cuid())
  shipmentId  String @map("shipment_id")
  productId   String @map("product_id")
  quantity    Int
  lotNumber   String? @map("lot_number")
  serialNumber String? @map("serial_number")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@map("shipment_items")
}

// ─── Carrier Rate Shopping ──────────────────────────────

model CarrierAccount {
  id          String  @id @default(cuid())
  name        String
  carrier     String  // ups, fedex, usps, dhl, etc.
  accountNumber String? @map("account_number")
  credentials Json    @default("{}")
  isActive    Boolean @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("carrier_accounts")
}

// ─── Infrastructure ─────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  action     String   // create, update, delete
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  changes    Json?    // { field: { old, new } }
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([userId])
  @@map("audit_log")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String
  message   String
  type      String   @default("info") // info, warning, error, success
  isRead    Boolean  @default(false) @map("is_read")
  link      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@map("notifications")
}

model SequenceCounter {
  id      String @id @default(cuid())
  prefix  String
  year    Int
  current Int    @default(0)

  @@unique([prefix, year])
  @@map("sequence_counters")
}
