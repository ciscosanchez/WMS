  operatorId    String?   @map("operator_id")
  role          String?
  hourlyRate    Decimal   @db.Decimal(10, 2) @map("hourly_rate")
  currency      String    @default("USD")
  effectiveFrom DateTime  @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("labor_rates")
}

// ─── Yard & Dock Scheduling ─────────────────────────────

enum DockDoorType {
  inbound
  outbound
  both
}

enum DockDoorStatus {
  available
  occupied
  maintenance
  closed
}

model DockDoor {
  id          String         @id @default(cuid())
  warehouseId String         @map("warehouse_id")
  code        String
  name        String
  type        DockDoorType   @default(both)
  status      DockDoorStatus @default(available)
  notes       String?
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  warehouse    Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  appointments DockAppointment[]

  @@unique([warehouseId, code])
  @@map("dock_doors")
}

enum YardSpotType {
  parking
  staging
  refrigerated
  hazmat
}

enum YardSpotStatus {
  empty
  occupied
  reserved
  blocked
}

model YardSpot {
  id          String         @id @default(cuid())
  warehouseId String         @map("warehouse_id")
  code        String
  name        String
  type        YardSpotType   @default(parking)
  status      YardSpotStatus @default(empty)
  row         Int?
  col         Int?           @map("col")
  notes       String?
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  warehouse  Warehouse   @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  yardVisits YardVisit[]

  @@unique([warehouseId, code])
  @@map("yard_spots")
}

enum AppointmentStatus {
  scheduled
  confirmed
  checked_in
  at_dock
  loading
  unloading
  completed
  cancelled
  no_show
}

enum AppointmentDirection {
  inbound
  outbound
}

model DockAppointment {
  id                  String               @id @default(cuid())
  appointmentNumber   String               @unique @map("appointment_number")
  warehouseId         String               @map("warehouse_id")
  dockDoorId          String?              @map("dock_door_id")
  direction           AppointmentDirection
  status              AppointmentStatus    @default(scheduled)
  // Timing
  scheduledStart      DateTime             @map("scheduled_start")
  scheduledEnd        DateTime             @map("scheduled_end")
  actualArrival       DateTime?            @map("actual_arrival")
  dockStart           DateTime?            @map("dock_start")
  dockEnd             DateTime?            @map("dock_end")
  // Driver / trailer info
  carrier             String?
  trailerNumber       String?              @map("trailer_number")
  driverName          String?              @map("driver_name")
  driverPhone         String?              @map("driver_phone")
  driverLicense       String?              @map("driver_license")
  // Linked entities
  inboundShipmentId   String?              @map("inbound_shipment_id")
  outboundShipmentId  String?              @map("outbound_shipment_id")
  clientId            String?              @map("client_id")
  // Metadata
  notes               String?
  cancelReason        String?              @map("cancel_reason")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  warehouse        Warehouse        @relation(fields: [warehouseId], references: [id])
  dockDoor         DockDoor?        @relation(fields: [dockDoorId], references: [id])
  inboundShipment  InboundShipment? @relation("inbound_appointment", fields: [inboundShipmentId], references: [id])
  outboundShipment Shipment?        @relation("outbound_appointment", fields: [outboundShipmentId], references: [id])
  client           Client?          @relation(fields: [clientId], references: [id])
  yardVisits       YardVisit[]

  @@index([warehouseId])
  @@index([status])
  @@index([scheduledStart])
  @@index([dockDoorId])
  @@index([clientId])
  @@map("dock_appointments")
}

enum YardVisitStatus {
  in_yard
  at_dock
  departed
}

model YardVisit {
  id            String          @id @default(cuid())
  yardSpotId    String          @map("yard_spot_id")
  appointmentId String?         @map("appointment_id")
  trailerNumber String          @map("trailer_number")
  carrier       String?
  sealNumber    String?         @map("seal_number")
  status        YardVisitStatus @default(in_yard)
  arrivedAt     DateTime        @default(now()) @map("arrived_at")
  departedAt    DateTime?       @map("departed_at")
  notes         String?
  createdAt     DateTime        @default(now()) @map("created_at")

  yardSpot    YardSpot         @relation(fields: [yardSpotId], references: [id])
  appointment DockAppointment? @relation(fields: [appointmentId], references: [id])

  @@index([yardSpotId])
  @@index([status])
  @@map("yard_visits")
}

// ─── Compliance & Customs ──────────────────────────────────────────

enum ComplianceStatus {
  comp_pending
  comp_cleared
  comp_flagged
  comp_blocked
}

model ComplianceCheck {
  id          String           @id @default(cuid())
  entityType  String           @map("entity_type")  // shipment, product, order
  entityId    String           @map("entity_id")
  checkType   String           @map("check_type")   // hs_code, hazmat, restricted, sanctions
  status      ComplianceStatus @default(comp_pending)
  details     String?
  resolvedBy  String?          @map("resolved_by")
  resolvedAt  DateTime?        @map("resolved_at")
  createdAt   DateTime         @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([status])
  @@map("compliance_checks")
}

model HazmatFlag {
  id            String  @id @default(cuid())
  productId     String  @unique @map("product_id")
  unNumber      String? @map("un_number")
  hazClass      String? @map("haz_class")
  packingGroup  String? @map("packing_group")
  properName    String? @map("proper_name")
  isRestricted  Boolean @default(false) @map("is_restricted")

  product Product @relation(fields: [productId], references: [id])

  @@map("hazmat_flags")
}

// ─── LPN / Container Tracking ──────────────────────────

enum LpnStatus {
  lpn_active
  lpn_in_transit
  lpn_consumed
}

model Lpn {
  id          String    @id @default(cuid())
  lpnNumber   String    @unique @map("lpn_number")
  binId       String?   @map("bin_id")
  status      LpnStatus @default(lpn_active)
  palletType  String?   @map("pallet_type")
  totalWeight Decimal?  @db.Decimal(10,4) @map("total_weight")
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  bin      Bin?        @relation(fields: [binId], references: [id])
  contents LpnContent[]

  @@index([binId])
  @@index([status])
  @@map("lpns")
}

model LpnContent {
  id           String  @id @default(cuid())
  lpnId        String  @map("lpn_id")
  productId    String  @map("product_id")
  quantity     Int
  lotNumber    String? @map("lot_number")
  serialNumber String? @map("serial_number")

  lpn     Lpn     @relation(fields: [lpnId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([lpnId])
  @@map("lpn_contents")
}

// ─── Cross-Dock Orchestration ──────────────────────────────────────

enum CrossDockStatus {
  cd_identified
  cd_approved
  cd_in_progress
  cd_completed
  cd_cancelled
}

model CrossDockRule {
  id        String   @id @default(cuid())
  clientId  String?  @map("client_id")
  productId String?  @map("product_id")
  isActive  Boolean  @default(true) @map("is_active")
  priority  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("cross_dock_rules")
}

model CrossDockPlan {
  id                  String          @id @default(cuid())
  inboundShipmentId   String          @map("inbound_shipment_id")
  outboundOrderId     String          @map("outbound_order_id")
  status              CrossDockStatus @default(cd_identified)
  productId           String          @map("product_id")
  quantity            Int
  sourceDockDoorId    String?         @map("source_dock_door_id")
  targetDockDoorId    String?         @map("target_dock_door_id")
  completedAt         DateTime?       @map("completed_at")
  createdAt           DateTime        @default(now()) @map("created_at")

  @@index([inboundShipmentId])
  @@index([outboundOrderId])
  @@index([status])
  @@map("cross_dock_plans")
}

// ─── Automation & Robotics ─────────────────────────────

enum DeviceType {
  amr
  conveyor
  pick_to_light
  put_to_light
  sortation
}

enum DeviceStatus {
  dev_online
  dev_offline
  dev_error
  dev_maintenance
}

model AutomationDevice {
  id           String       @id @default(cuid())
  warehouseId  String       @map("warehouse_id")
  code         String
  name         String
  type         DeviceType
  status       DeviceStatus @default(dev_offline)
  zoneId       String?      @map("zone_id")
  ipAddress    String?      @map("ip_address")
  lastPingAt   DateTime?    @map("last_ping_at")
  config       Json         @default("{}")
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  deviceTasks DeviceTask[]

  @@unique([warehouseId, code])
  @@map("automation_devices")
}

model DeviceTask {
  id          String   @id @default(cuid())
  deviceId    String   @map("device_id")
  taskType    String   @map("task_type")    // transport, sort, pick_signal, put_signal
  status      String   @default("queued")   // queued, dispatched, in_progress, completed, failed
  payload     Json     @default("{}")
  result      Json?
  dispatchedAt DateTime? @map("dispatched_at")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  device AutomationDevice @relation(fields: [deviceId], references: [id])

  @@index([deviceId])
  @@index([status])
  @@map("device_tasks")
}

// ─── Document Intelligence (DocAI) ─────────────────────

model DocumentProcessingJob {
  id            String   @id @default(cuid())
  documentId    String?  @map("document_id")
  sourceType    String   @map("source_type")    // upload, email, camera, scanner
  documentType  String?  @map("document_type")   // bol, packing_list, invoice, etc.
  status        String   @default("pending")     // pending, processing, review, completed, failed
  fileUrl       String   @map("file_url")
  fileName      String   @map("file_name")
  mimeType      String?  @map("mime_type")

  // AI extraction results
  extractedData Json?    @map("extracted_data")  // structured JSON from DocAI
  confidence    Float?                            // overall confidence 0-1
  aiModel       String?  @map("ai_model")        // which model was used
  aiCost        Float?   @map("ai_cost")         // API cost for tracking

  // Human review
  reviewedData  Json?    @map("reviewed_data")   // corrected data after review
  reviewedBy    String?  @map("reviewed_by")
  reviewedAt    DateTime? @map("reviewed_at")

  // Result
  resultType    String?  @map("result_type")     // shipment, order, product_update
  resultId      String?  @map("result_id")       // ID of created entity

  // Metadata
  requestId     String?  @map("request_id")      // DocAI request ID for tracing
  tenantId      String?  @map("tenant_id")       // for multi-tenant scoping

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  processedAt   DateTime? @map("processed_at")

  // Relations
  document      Document? @relation(fields: [documentId], references: [id])

  @@index([status])
  @@index([documentType])
  @@index([tenantId])
  @@index([createdAt])
  @@map("document_processing_jobs")
}

// ─── Transfer Orders (Multi-Warehouse) ──────────────────

enum TransferOrderStatus {
  draft
  approved
  in_transit
  received
  completed
  cancelled
}

model TransferOrder {
  id                 String              @id @default(cuid())
  transferNumber     String              @unique @map("transfer_number")
  fromWarehouseId    String              @map("from_warehouse_id")
  toWarehouseId      String              @map("to_warehouse_id")
  status             TransferOrderStatus @default(draft)
  requestedBy        String              @map("requested_by")
  approvedBy         String?             @map("approved_by")
  approvedAt         DateTime?           @map("approved_at")
  shippedAt          DateTime?           @map("shipped_at")
  receivedAt         DateTime?           @map("received_at")
  notes              String?
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  fromWarehouse Warehouse           @relation("transfer_from", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse           @relation("transfer_to", fields: [toWarehouseId], references: [id])
  lines         TransferOrderLine[]

  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([status])
  @@map("transfer_orders")
}

model TransferOrderLine {
  id              String  @id @default(cuid())
  transferOrderId String  @map("transfer_order_id")
  productId       String  @map("product_id")
  quantity        Int
  receivedQty     Int     @default(0) @map("received_qty")
  lotNumber       String? @map("lot_number")
  notes           String?

  transferOrder TransferOrder @relation(fields: [transferOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@index([transferOrderId])
  @@map("transfer_order_lines")
}

// ─── Replenishment Rules ────────────────────────────────

model ReplenishmentRule {
  id           String   @id @default(cuid())
  productId    String   @map("product_id")
  binId        String   @map("bin_id")
  minQty       Int      @map("min_qty")
  maxQty       Int      @map("max_qty")
  reorderPoint Int      @map("reorder_point")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id])
  bin     Bin     @relation(fields: [binId], references: [id])

  @@unique([productId, binId])
  @@index([productId])
  @@index([binId])
  @@map("replenishment_rules")
}

// ─── Customs & Freight ─────────────────────────────────

enum CustomsEntryStatus {
  ce_draft
  ce_pending
  ce_filed
  ce_cleared
  ce_held
  ce_rejected
}

model CustomsEntry {
  id              String             @id @default(cuid())
  entryNumber     String?            @unique @map("entry_number")
  shipmentId      String?            @map("shipment_id")
  entryType       String             @map("entry_type")
  status          CustomsEntryStatus @default(ce_draft)
  portOfEntry     String?            @map("port_of_entry")
  carrier         String?
  vesselName      String?            @map("vessel_name")
  voyageNumber    String?            @map("voyage_number")
  estimatedArrival DateTime?         @map("estimated_arrival")
  filedAt         DateTime?          @map("filed_at")
  clearedAt       DateTime?          @map("cleared_at")
  brokerName      String?            @map("broker_name")
  brokerRef       String?            @map("broker_ref")
  totalDuty       Decimal?           @db.Decimal(10,2) @map("total_duty")
  notes           String?
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  lines CustomsEntryLine[]

  @@index([status])
  @@index([shipmentId])
  @@map("customs_entries")
}

model CustomsEntryLine {
  id           String  @id @default(cuid())
  entryId      String  @map("entry_id")
  hsCode       String  @map("hs_code")
  description  String
  countryOrigin String @map("country_origin")
  quantity     Int
  value        Decimal @db.Decimal(10,2)
  dutyRate     Decimal? @db.Decimal(10,4) @map("duty_rate")
  dutyAmount   Decimal? @db.Decimal(10,2) @map("duty_amount")

  entry CustomsEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
  @@map("customs_entry_lines")
}

model BondedInventory {
  id          String   @id @default(cuid())
  productId   String   @map("product_id")
  binId       String?  @map("bin_id")
  entryId     String?  @map("entry_id")
  quantity    Int
  bondNumber  String?  @map("bond_number")
  bondType    String?  @map("bond_type")
  entryDate   DateTime @map("entry_date")
  releaseDate DateTime? @map("release_date")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@index([entryId])
  @@map("bonded_inventory")
}
